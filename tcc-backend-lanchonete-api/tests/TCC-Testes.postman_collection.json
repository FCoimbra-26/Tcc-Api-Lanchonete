    {
      "name": "02 - Criar unidade",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token_gerente_ou_admin}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"codigo\": \"UN{{$timestamp}}\",\n  \"nome\": \"Unidade Centro\",\n  \"canaisAtendimento\": [0, 1, 2],\n  \"endereco\": {\n    \"logradouro\": \"Rua das Flores\",\n    \"numero\": \"100\",\n    \"complemento\": \"Loja 1\",\n    \"bairro\": \"Centro\",\n    \"cidade\": \"Sao Paulo\",\n    \"uf\": \"SP\",\n    \"cep\": \"01234567\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Unidade",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Unidade"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 2xx', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "let data = {};",
              "try { data = pm.response.json(); } catch (e) {}",
              "const unidadeId = data.id || data.unidadeId || null;",
              "const unidadeCodigo = data.codigo || null;",
              "if (unidadeId) pm.collectionVariables.set('unidadeId', String(unidadeId));",
              "if (unidadeCodigo) pm.collectionVariables.set('unidadeCodigo', String(unidadeCodigo));"
            ]
          }
        }
      ]
    },
