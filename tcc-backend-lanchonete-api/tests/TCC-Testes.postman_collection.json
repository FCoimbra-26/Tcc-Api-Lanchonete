  "item": [
    {
      "name": "00 - Autenticacao cliente",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{login_cliente_email}}\",\n  \"senha\": \"{{login_cliente_senha}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login cliente ok', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "let data = {};",
              "try { data = pm.response.json(); } catch (e) {}",
              "const token = data.token || data.Token || null;",
              "if (token) {",
              "    pm.collectionVariables.set('token', String(token));",
              "    pm.collectionVariables.set('token_cliente', String(token));",
              "    pm.collectionVariables.set('token_cliente_ou_admin', String(token));",
              "}"
            ]
          }
        }
      ]
    },
